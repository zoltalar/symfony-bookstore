{% extends 'base.html.twig' %}

{% block title %}Shopping Cart{% endblock %}

{% block body %}
    <h5 class="mb-3">Your Shopping Cart ({{ items|length }})</h5>
    <hr />
    {% if (items|length > 0) %}
        <form action="{{ path('app.cart.index') }}" method="post" id="cart">
            <div class="row">
                <div class="col-lg-8">
                    <div class="card mb-3">
                        <div class="card-body">
                            {% for item in items %}
                                <div id="cart-item-{{ item.id }}" class="row cart-item {% if not loop.last %} mb-3 {% endif %}" data-cart-item="{{ item.id }}">
                                    <div class="col-md-7">
                                        <p class="card-title mb-0">{{ item.book.title }}</p>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="input-group">
                                            <button
                                                type="button"
                                                class="btn btn-outline-secondary btn-sm"
                                                onclick="decrementQuantity({{ item.id }})"
                                            >
                                                -
                                            </button>
                                            <input type="text" name="quantities[{{ item.id }}]" class="form-control form-control-sm text-center" value="{{ item.quantity }}">
                                            <button
                                                type="button"
                                                class="btn btn-outline-secondary btn-sm"
                                                onclick="incrementQuantity({{ item.id }})"
                                            >
                                                +
                                            </button>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <p class="fw-bold text-danger text-center">
                                            $<span id="cart-item-subtotal-{{ item.id }}">{{ item.subtotal }}</span>
                                        </p>
                                    </div>
                                    <div class="col-md-1 text-end">
                                        <button type="submit" name="deleteCartItem" class="btn btn-outline-secondary btn-sm" onclick="return confirmCartItemDeletion({{ item.id }});">🗑</button>
                                    </div>
                                </div>
                                {% if not loop.last %}
                                    <hr id="separator-{{ item.id }}" />
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div>
                        <a href="{{ path('app.books.index') }}" class="btn btn-primary"> ❮ Continue Shopping</a>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="fw-bold card-title mb-3">Order Summary</h6>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal</span>
                                <span>
                                    $<span id="cart-subtotal">{{ cart.subtotal }}</span>
                                </span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping</span>
                                <span>
                                    $<span id="cart-shipping">{{ cart.shipping }}</span>
                                </span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tax</span>
                                <span>
                                    $<span id="cart-tax">{{ cart.tax }}</span>
                                </span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between mb-3">
                                <strong>Total</strong>
                                <strong class="text-danger">
                                    $<span id="cart-total">{{ cart.total }}</span>
                                </strong>
                            </div>
                            <div class="d-grid">
                                <button class="btn btn-primary">Proceed to Checkout ❯ </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <input type="hidden" name="itemId" value="" />
            <input type="hidden" name="action" value="" />
        </form>
    {% endif %}
    <div id="alert-cart-empty" class="alert alert-info {% if items|length > 0 %} d-none {% endif %}">
        Your shopping cart is empty.
    </div>
{% endblock %}

{% block javascripts %}
    <script type="text/javascript">
        const confirmCartItemDeletion = (id) => {
            if (confirm('Are you sure?')) {
                const form = document.getElementById('cart')
                form.method = 'post'
                form.elements['itemId'].value = id
                form.elements['action'].value = 'delete'
                return true
            } else {
                return false;
            }
        }
        const decrementQuantity = (id) => {
            const form = document.getElementById('cart')
            const element = form.elements['quantities[' + id + ']']
            let quantity = element.value
            if (isNaN(quantity)) {
                quantity = 1
            }
            if (quantity > 0) {
                quantity--
            }
            element.value = quantity
            updateCart()
        }
        const incrementQuantity = (id) => {
            const form = document.getElementById('cart')
            const element = form.elements['quantities[' + id + ']']
            const max = 100
            let quantity = element.value
            if (isNaN(quantity)) {
                quantity = 1
            }
            if (quantity < max) {
                quantity++
            }
            element.value = quantity
            updateCart()
        }
        const hideOrphans = (ids) => {
            const items = document.querySelectorAll('.cart-item')
            items.forEach((item, i) => {
                const cartId = Number(item.getAttribute('data-cart-item'))
                if (! ids.includes(cartId)) {
                    item.classList.add('d-none')
                    document.getElementById('separator-' + cartId).classList.add('d-none')
                }
            })
        }
        const updateCart = async () => {
            const form = document.getElementById('cart')
            const formData = new FormData(form)
            formData.set('action', 'update')
            try {
                const response = await fetch('/cart/index', {
                    method: 'POST',
                    headers: {
                        accept: 'application/json'
                    },
                    body: formData
                })
                const result = await response.json()
                if (Array.isArray(result.items)) {
                    if (result.items.length === 0) {
                        document.getElementById('alert-cart-empty').classList.remove('d-none')
                        document.getElementById('cart').classList.add('d-none')
                    } else {
                        let cartIds = []
                        result.items.forEach((item, i) => {
                            cartIds.push(Number(item.id))
                            document.getElementById('cart-item-subtotal-' + item.id).innerText = item.book_subtotal
                        })
                        hideOrphans(cartIds)
                        document.getElementById('cart-subtotal').innerText = result.subtotal
                        document.getElementById('cart-shipping').innerText = result.shipping
                        document.getElementById('cart-tax').innerText = result.tax
                        document.getElementById('cart-total').innerText = result.total
                    }
                }                
            } catch (error) {
                console.log(error)
            }
        }
    </script>
{% endblock %}
