{% extends 'base.html.twig' %}

{% block title %} {{ book.title }} {% endblock %}

{% block body %}
    <a href="{{ path('app.books.edit', { 'id': book.id }) }}" class="btn float-end">✏️️</a>
    <a href="{{ path('app.books.index') }}" class="btn btn-sm btn-outline-primary me-2">Back</a>
    <hr />
    <div class="row">
        <div class="col-md-4">
            {% if book.images|first %}
                <div class="card">
                    <div class="card-body">
                        <img src="{{ image_path(book.images|first.file) }}" alt="{{ book.title }}" class="img-fluid mb-3" />
                    </div>
                </div>
            {% endif %}
        </div>
        <div class="col-md-8">
            <h5>{{ book.title }}</h5>
            {% if (book.authors|length > 0) %}
                <p class="mb-2">
                    by
                    {% for author in book.authors %}{{ author.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                </p>
            {% endif %}
            <p class="small text-secondary mb-1">ISBN: {{ book.isbn }}</p>
            <p class="text-danger mb-2">
                <strong>${{ book.price }}</strong>
            </p>
            <form action="{{ path('app.cart.add', { 'id': book.id }) }}" method="post" class="mt-3 mb-3">
                <button type="submit" class="btn btn-lg btn-primary">
                    Add to Cart
                </button>
            </form>
            <p>
                {{ book.description|nl2br }}
            </p>
        </div>
    </div>
{% endblock %}
