{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <h5 class="mb-3">Register</h5>
    <hr />
    <div class="row">
        <div class="col-4 mx-auto">
            {{ form_start(form, {'attr': {'class': 'mt-3'}}) }}
                {{ form_widget(form) }}
            {{ form_end(form) }}
            <div>
                <p>Already registered? <a href="{{ path('app.login') }}">Login</a></p>
            </div>
        </div>
    </div>    
{% endblock %}